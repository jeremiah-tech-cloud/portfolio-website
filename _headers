/*
  # Strict-Transport-Security
  # Forces HTTPS for 2 years. Once deployed on Netlify (which gives you
  # free HTTPS automatically), this ensures no one can access your site
  # over plain HTTP even if they type http:// in the address bar.
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # X-Frame-Options
  # Prevents your site from being embedded inside an iframe on another
  # website — blocks clickjacking attacks completely.
  X-Frame-Options: DENY

  # X-Content-Type-Options
  # Stops browsers from guessing (sniffing) file types. Without this a
  # browser might execute a .jpg as a script if a bad actor tricks it.
  X-Content-Type-Options: nosniff

  # Referrer-Policy
  # When a visitor clicks your GitHub or WhatsApp link, this controls
  # how much of your URL is passed along. strict-origin-when-cross-origin
  # shares the origin only — not the full path.
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions-Policy
  # Your portfolio never needs camera, microphone, or geolocation.
  # This header locks those browser features off entirely for your site.
  Permissions-Policy: camera=(), microphone=(), geolocation(), payment=()

  # Content-Security-Policy
  # The most powerful header — controls exactly where scripts, styles,
  # fonts, and images are allowed to load from.
  #
  # default-src 'self'        → only load resources from your own domain
  # script-src 'self' 'unsafe-inline' → allows your inline JS (index.js)
  # style-src 'self' 'unsafe-inline'  → allows your inline CSS (style.css)
  # img-src 'self' data:      → allows your local images + base64 images
  # font-src 'self'           → allows your local fonts (all.min.css icons)
  # connect-src 'none'        → blocks all outbound fetch/XHR (you have none)
  # frame-ancestors 'none'    → double-locks iframe embedding (with X-Frame-Options)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'none'; frame-ancestors 'none';
